  </div>

  <script>
  const LIVE_PATH = '/pl/plots/villajoyosa-sea-plot-3-2m/';
  function categoryPath(lang){ return `https://costa-blanca-invest.com/${lang}/plots/`; }
  const SUPPORTED_LANGS = ['ru', 'es', 'en', 'pl'];

  const TRANSLATIONS = {
    ru: {
      lang: 'ru', locale: 'ru_RU',
      page_title: 'Участок в черте города Аликанте | 465 м² | € 3 200 000',
      meta_description: 'Продаётся городской участок в Аликанте площадью 465 м². Разрешено строительство частного дома до 2 этажей. Все коммуникации подключены. Цена € 3 200 000.',
