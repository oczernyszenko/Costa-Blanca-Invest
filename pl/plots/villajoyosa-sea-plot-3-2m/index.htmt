      spec_title: 'Co otrzymuje kupujący', spec_1: 'Działkę miejską 465 m² w Alicante', spec_2: 'Możliwość zabudowy do 230 m²', spec_3: 'Możliwość budowy domu linia morza', spec_4: 'Podłączone media: woda, prąd, kanalizacja', spec_5: 'Oświetlenie uliczne i ukształtowane otoczenie mieszkaniowe', spec_6: 'Wygodny dostęp do centrum Alicante', spec_paragraph: 'To propozycja dla osoby, która nie chce zaczynać od zera i szuka działki z gotową infrastrukturą techniczną.',
      roi_title: 'Potencjał nieruchomości', roi_paragraph_1: 'Największą wartością tej działki jest jej miejski charakter i gotowość do budowy. Dla klienta prywatnego to szansa na stworzenie nowoczesnego domu w Alicante bez rezygnacji z wygody miasta.', roi_label_1: 'Format:', roi_value_1: 'działka pod prywatny dom mieszkalny', roi_label_2: 'Lokalizacja:', roi_value_2: 'spokojna dzielnica mieszkaniowa Alicante', roi_label_3: 'Gotowość:', roi_value_3: 'media podłączone, działka gotowa do zabudowy', roi_label_4: 'Atut:', roi_value_4: 'szybszy start projektu i łatwy dojazd do centrum', roi_paragraph_2: 'Dla inwestora to również czytelny aktyw miejski w lokalizacji, gdzie dobrze położone domy jednorodzinne pozostają atrakcyjne.',
      audience_title: 'Dla kogo jest ta działka?', audience_card_1_title: '🏡 Dla klienta prywatnego', audience_card_1_text: 'Dla osoby, która chce wybudować własny dom w Alicante i mieszkać w mieście.', audience_card_2_title: '👨‍👩‍👧 Dla rodziny', audience_card_2_text: 'Dla rodziny, która ceni spokojną okolicę, podłączone media i możliwość budowy wygodnego domu na dwóch poziomach.', audience_card_3_title: '📈 Dla inwestora', audience_card_3_text: 'Dla kupującego, który postrzega płynną działkę miejską jako bazę pod jakościowy projekt mieszkaniowy.',
      urgency_note: 'Pierwsza linia morza · projekt deweloperski · wysoki potencjał', contact_title: 'Otrzymaj szczegóły działki', contact_intro: 'Skontaktuj się ze mną, aby otrzymać więcej informacji o działce, parametrach zabudowy i możliwości obejrzenia nieruchomości.', agent_role: 'Ekspert ds. nieruchomości na Costa Blanca', agent_meta: 'Dobór nieruchomości, wsparcie przy zakupie i pomoc na każdym etapie transakcji w Hiszpanii.', call_btn: 'Zadzwoń', wa_btn: 'WhatsApp', copy_link: 'Kopiuj link', share_btn: 'Udostępnij', share_note_title: 'Działka na pierwszej linii morza w Villajoyosa', share_note_strong: '€ 3 200 000 · 24 apartamenty · 2 budynki', share_note_text: 'Bezpośredni widok na morze · projekt premium · wysoki potencjał inwestycyjny', form_name: 'Imię', form_phone: 'Telefon', form_email: 'Email', form_message: 'Napisz, czy interesuje Cię projekt deweloperski, zakup inwestycyjny lub szczegóły działki', form_submit: 'Wyślij przez WhatsApp', wa_form_prefix: 'Nowe zapytanie ze strony'
    }
  };

  const PROPERTY_DATA = { slug: 'villajoyosa-sea-plot-3-2m', images: ['1.jpg','2.jpg','3.jpg','4.jpg','5.jpg','6.jpg','7.jpg','8.jpg','9.jpg'], contact_phone: '+34604158859' };

  document.addEventListener('DOMContentLoaded', () => {
    const contactForm = document.getElementById('contact-form');
    const mediaLightbox = document.getElementById('mediaLightbox');
    const mediaLightboxContent = document.getElementById('mediaLightboxContent');
    const mediaLightboxClose = document.getElementById('mediaLightboxClose');
    const mediaTriggers = Array.from(document.querySelectorAll('[data-media-src]'));
    const copyLinkBtn = document.getElementById('copyLinkBtn');
    const nativeShareBtn = document.getElementById('nativeShareBtn');
    const langButtons = Array.from(document.querySelectorAll('.lang-btn'));
    const fallbackAvatar = 'https://costa-blanca-invest.com/avatar.png';
    const backLink = document.getElementById('backLink');
    const backLinkLabel = document.getElementById('backLinkLabel');
    let currentLang = 'pl';

    function imageBaseAbsolute(lang = currentLang) { return `https://costa-blanca-invest.com/${lang}/plots/${PROPERTY_DATA.slug}/`; }
    function imageBaseRelative() { return './'; }
    function listingUrl(lang = currentLang) { return `https://costa-blanca-invest.com/${lang}/plots/${PROPERTY_DATA.slug}/`; }

    window.handleBrokenImage = function(img) {
      if (img.dataset.fallbackApplied === 'true') return;
      img.dataset.fallbackApplied = 'true';
      if (img.classList.contains('agent-avatar')) {
        img.src = fallbackAvatar;
        return;
      }
      img.src = '1.jpg';
    };

    function setAttr(selector, attr, value) {
      const el = document.querySelector(selector);
      if (el) el.setAttribute(attr, value);
    }

    function applyMeta(t) {
      document.documentElement.lang = t.lang;
      document.title = t.page_title;
      setAttr('meta[name="description"]', 'content', t.meta_description);
      setAttr('link[rel="canonical"]', 'href', listingUrl(currentLang));
      setAttr('link[rel="image_src"]', 'href', `${imageBaseAbsolute(currentLang)}1.jpg`);
      setAttr('meta[property="og:locale"]', 'content', t.locale);
      setAttr('meta[property="og:title"]', 'content', t.og_title);
      setAttr('meta[property="og:description"]', 'content', t.og_description);
      setAttr('meta[property="og:url"]', 'content', listingUrl(currentLang));
      setAttr('meta[property="og:image"]', 'content', `${imageBaseAbsolute(currentLang)}1.jpg`);
      setAttr('meta[property="og:image:url"]', 'content', `${imageBaseAbsolute(currentLang)}1.jpg`);
      setAttr('meta[property="og:image:secure_url"]', 'content', `${imageBaseAbsolute(currentLang)}1.jpg`);
      setAttr('meta[property="og:image:alt"]', 'content', t.og_image_alt);
      setAttr('meta[name="twitter:title"]', 'content', t.og_title);
      setAttr('meta[name="twitter:description"]', 'content', t.og_description);
      setAttr('meta[name="twitter:image"]', 'content', `${imageBaseAbsolute(currentLang)}1.jpg`);
      setAttr('meta[name="twitter:image:alt"]', 'content', t.og_image_alt);
      setAttr('meta[name="twitter:url"]', 'content', listingUrl(currentLang));
    }

    function applyText(t) {
      document.querySelectorAll('[data-i18n]').forEach((el) => {
        const key = el.dataset.i18n;
        if (t[key]) el.textContent = t[key];
      });
      if (backLink) backLink.href = categoryPath(currentLang);
      if (backLinkLabel) backLinkLabel.textContent = t.back_link;
      const formName = document.getElementById('formName');
      const formPhone = document.getElementById('formPhone');
      const formEmail = document.getElementById('formEmail');
      const formMessage = document.getElementById('formMessage');
      if (formName) formName.placeholder = t.form_name;
      if (formPhone) formPhone.placeholder = t.form_phone;
      if (formEmail) formEmail.placeholder = t.form_email;
      if (formMessage) formMessage.placeholder = t.form_message;
    }

    function applyImages() {
      const relative = imageBaseRelative();
      const currentText = TRANSLATIONS[currentLang] || TRANSLATIONS.pl;
      const heroImage = document.getElementById('heroImage');
      if (heroImage) {
        heroImage.src = `${relative}${PROPERTY_DATA.images[0]}`;
        heroImage.alt = currentText.og_image_alt;
      }
      mediaTriggers.forEach((item, index) => {
        const fileName = PROPERTY_DATA.images[index] || PROPERTY_DATA.images[0];
        const src = `${relative}${fileName}`;
        item.dataset.mediaSrc = src;
        const img = item.querySelector('img');
        if (img) {
          img.src = src;
          img.alt = index === 0 ? currentText.og_image_alt : `${currentText.hero_title} ${index + 1}`;
        }
      });
    }

    function applyLanguage(lang) {
      currentLang = SUPPORTED_LANGS.includes(lang) ? lang : 'pl';
      const t = TRANSLATIONS[currentLang] || TRANSLATIONS.pl;
      applyMeta(t);
      applyText(t);
      applyImages();
      langButtons.forEach((btn) => btn.classList.toggle('active', btn.dataset.lang === currentLang));
    }

    function openMediaLightbox(src) {
      if (!mediaLightbox || !mediaLightboxContent) return;
      mediaLightboxContent.innerHTML = `<img src="${src}" alt="Preview">`;
      mediaLightbox.classList.add('open');
      mediaLightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeMediaLightbox() {
      if (!mediaLightbox || !mediaLightboxContent) return;
      mediaLightbox.classList.remove('open');
      mediaLightbox.setAttribute('aria-hidden', 'true');
      mediaLightboxContent.innerHTML = '';
      document.body.style.overflow = '';
    }

    mediaTriggers.forEach((item) => item.addEventListener('click', () => openMediaLightbox(item.dataset.mediaSrc)));
    if (mediaLightboxClose) mediaLightboxClose.addEventListener('click', closeMediaLightbox);
    if (mediaLightbox) mediaLightbox.addEventListener('click', (event) => { if (event.target === mediaLightbox) closeMediaLightbox(); });
    document.addEventListener('keydown', (event) => { if (event.key === 'Escape' && mediaLightbox?.classList.contains('open')) closeMediaLightbox(); });

    if (copyLinkBtn) {
      copyLinkBtn.addEventListener('click', async () => {
        const shareUrl = listingUrl(currentLang);
        const label = copyLinkBtn.querySelector('span');
        const original = label ? label.textContent : 'Copy link';
        try {
          await navigator.clipboard.writeText(shareUrl);
          if (label) label.textContent = '✔';
          setTimeout(() => { if (label) label.textContent = (TRANSLATIONS[currentLang] || TRANSLATIONS.pl).copy_link; }, 1800);
        } catch (error) {
          window.prompt('Copy link:', shareUrl);
          if (label) label.textContent = original;
        }
      });
    }

    if (nativeShareBtn) {
      nativeShareBtn.addEventListener('click', async () => {
        const t = TRANSLATIONS[currentLang] || TRANSLATIONS.pl;
        const shareData = {
          title: t.og_title,
          text: `${t.share_note_title} · ${t.share_note_strong}`,
          url: listingUrl(currentLang)
        };
        if (navigator.share) {
          try { await navigator.share(shareData); } catch (error) {}
        } else {
          try {
            await navigator.clipboard.writeText(shareData.url);
            const label = nativeShareBtn.querySelector('span');
            if (label) {
              label.textContent = '✔';
              setTimeout(() => { label.textContent = t.share_btn; }, 1800);
            }
          } catch (error) {
            window.prompt('Copy link:', shareData.url);
          }
        }
      });
    }

    if (contactForm) {
      contactForm.addEventListener('submit', (event) => {
        event.preventDefault();
        const t = TRANSLATIONS[currentLang] || TRANSLATIONS.pl;
        const formData = new FormData(contactForm);
        const name = String(formData.get('name') || '').trim();
        const phone = String(formData.get('phone') || '').trim();
        const email = String(formData.get('email') || '').trim();
        const message = String(formData.get('message') || '').trim();
        const text = `${t.wa_form_prefix}\n\n${t.form_name}: ${name}\n${t.form_phone}: ${phone}\n${t.form_email}: ${email}\n\n${message}`;
        const url = `https://wa.me/34604158859?text=${encodeURIComponent(text)}`;
        const opened = window.open(url, '_blank', 'noopener');
        if (!opened) window.location.href = url;
      });
    }

    langButtons.forEach((btn) => btn.addEventListener('click', () => applyLanguage(btn.dataset.lang)));
    applyLanguage('pl');
  });
  </script>

