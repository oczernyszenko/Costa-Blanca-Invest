  <style>
    :root {
      --primary: #183746;
      --primary-2: #234e63;
      --primary-soft: #9ec7d4;
      --gold: #d9b56d;
      --gold-dark: #b89245;
      --bg: #f6f3ee;
      --text: #172532;
      --text-soft: #62707c;
      --muted: #8e9aa4;
      --surface: rgba(255,255,255,.88);
      --shadow-soft: 0 14px 34px rgba(15,23,42,.06);
      --radius: 28px;
      --container: 1280px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      overflow-x: hidden;
      font-family: Inter, Arial, sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(217,181,109,.12), transparent 24%),
        radial-gradient(circle at top right, rgba(158,199,212,.14), transparent 28%),
        linear-gradient(180deg, #fdfbf8 0%, var(--bg) 52%, #fff 100%);
      line-height: 1.72;
    }

    img { display: block; max-width: 100%; height: auto; }
    a { color: inherit; text-decoration: none; }
    h1, h2, h3 { margin: 0 0 14px; line-height: 1.08; }
    p { margin: 0 0 14px; color: var(--text-soft); }
    ul { margin: 0; padding-left: 0; list-style: none; color: var(--text-soft); }
    ul li { position: relative; padding-left: 28px; margin-bottom: 8px; }
    ul li::before { content: "✔"; position: absolute; left: 0; top: 0; color: var(--gold); font-weight: 900; }

    .container { width: 100%; max-width: var(--container); margin: 0 auto; padding: 0 20px; }
    .page { padding: 24px 0 80px; }

    .top-controls {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: nowrap;
      margin-bottom: 20px;
    }

    .lang-switcher { display: flex; gap: 10px; align-items: center; justify-content: flex-end; margin: 0; }
    .lang-btn {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      border: 1px solid rgba(217,181,109,.5);
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      background: linear-gradient(135deg, rgba(217,181,109,.6), rgba(184,146,69,.6));
      color: #fff;
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      box-shadow: 0 10px 24px rgba(0,0,0,.12);
      transition: all .2s ease;
    }
    .lang-btn.active {
      background: #fff;
      color: var(--gold-dark);
      box-shadow: 0 6px 16px rgba(0,0,0,.12);
    }

    .back-link {
      position: sticky;
      top: 14px;
      z-index: 20;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      margin: 0;
      padding: 12px 18px;
      border-radius: 999px;
      background: linear-gradient(135deg, rgba(255,255,255,.30), rgba(255,255,255,.12));
      border: 1px solid rgba(255,255,255,.36);
      box-shadow: 0 14px 28px rgba(15,23,42,.10), inset 0 1px 0 rgba(255,255,255,.30);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      color: var(--gold-dark);
      font-size: 15px;
      font-weight: 800;
    }

    .hero-card, .section-card, .cta-box {
      position: relative;
      overflow: hidden;
      border-radius: var(--radius);
      background: var(--surface);
      border: 1px solid rgba(255,255,255,.40);
      box-shadow: 0 20px 50px rgba(15,23,42,.08), 0 0 0 1px rgba(255,255,255,.14) inset;
    }

    .hero-card { padding: 20px; }
    .section-card, .cta-box { margin-top: 32px; padding: 40px; }

    .hero-media {
      position: relative;
      overflow: hidden;
      min-height: 700px;
      border-radius: 26px;
      background: #e7edf1;
      box-shadow: 0 30px 90px rgba(15,23,42,.22);
      cursor: zoom-in;
    }
    .hero-media::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(8,14,20,.06) 0%, rgba(8,14,20,.14) 34%, rgba(8,14,20,.62) 100%);
      z-index: 1;
      pointer-events: none;
    }
    .hero-media img {
      width: 100%;
      height: 100%;
      min-height: 700px;
      object-fit: cover;
      object-position: center;
    }

    .hero-badge {
      position: absolute;
      top: 22px;
      right: 22px;
      z-index: 3;
      padding: 12px 18px;
      border-radius: 999px;
      background: rgba(255,255,255,.18);
      color: #fff;
      border: 1px solid rgba(255,255,255,.22);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: .18em;
      text-transform: uppercase;
    }

    .hero-overlay {
      position: absolute;
      left: 24px;
      right: 24px;
      bottom: 24px;
      z-index: 3;
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      gap: 20px;
      flex-wrap: wrap;
    }

    .hero-copy { max-width: 760px; }
    .hero-kicker {
      margin-bottom: 10px;
      color: rgba(255,255,255,.82);
      font-size: 11px;
      font-weight: 800;
      letter-spacing: .22em;
      text-transform: uppercase;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 999px;
      background: rgba(255,255,255,.12);
      border: 1px solid rgba(255,255,255,.16);
    }

    .hero-display {
      margin: 0 0 14px;
      color: #fff;
      font-size: clamp(40px, 5.6vw, 78px);
      font-weight: 900;
      letter-spacing: -.05em;
      line-height: .94;
      text-shadow: 0 16px 34px rgba(0,0,0,.24);
      max-width: 11ch;
    }

    .hero-sub { max-width: 620px; color: rgba(255,255,255,.9); font-size: 15px; }

    .hero-price-box {
      min-width: 320px;
      max-width: 360px;
      padding: 20px 22px;
      border-radius: 26px;
      background: linear-gradient(180deg, rgba(255,255,255,.26) 0%, rgba(255,255,255,.12) 100%);
      border: 1px solid rgba(255,255,255,.24);
      color: #fff;
      box-shadow: 0 18px 40px rgba(0,0,0,.16);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      text-align: left;
    }

    .hero-price-box small {
      display: block;
      margin-bottom: 10px;
      font-size: 10px;
      letter-spacing: .22em;
      text-transform: uppercase;
      opacity: .78;
      font-weight: 800;
    }

    .hero-price-range { display: flex; align-items: flex-end; gap: 10px; margin: 4px 0 10px; flex-wrap: wrap; }
    .hero-price-from, .hero-price-to {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 124px;
      padding: 14px 16px 12px;
      border-radius: 22px;
      background: linear-gradient(180deg, rgba(255,255,255,.22), rgba(255,255,255,.08));
      border: 1px solid rgba(255,255,255,.18);
      color: #fff8d6;
      font-size: clamp(24px, 3vw, 36px);
      line-height: 1;
      font-weight: 900;
      letter-spacing: -.05em;
    }
    .hero-price-sep { font-size: 20px; font-weight: 900; color: #fff; opacity: .92; padding-bottom: 8px; }
    .hero-price-note { display: block; margin-top: 6px; font-size: 13px; line-height: 1.5; color: rgba(255,255,255,.96); font-weight: 700; }
    .hero-price-meta { display: block; margin-top: 8px; font-size: 12px; line-height: 1.55; opacity: .94; }

    .gallery-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 18px; margin-top: 18px; }
    .gallery-item {
      position: relative;
      overflow: hidden;
      border-radius: 22px;
      background: #edf1f4;
      border: 1px solid rgba(255,255,255,.34);
      box-shadow: 0 20px 44px rgba(15,23,42,.10);
      cursor: zoom-in;
      min-height: 220px;
    }
    .gallery-item img { width: 100%; height: 100%; display: block; object-fit: cover; }

    .content { margin-top: 34px; }
    .hero-title, .subtitle, .price, .price-soft { text-align: center; }
    .hero-title {
      max-width: 980px;
      margin: 0 auto 12px;
      color: var(--primary);
      font-size: clamp(38px, 5.2vw, 60px);
      letter-spacing: -.04em;
      text-wrap: balance;
    }
    .subtitle { margin-bottom: 10px; color: var(--text-soft); font-size: 18px; }
    .price { margin-bottom: 10px; color: var(--gold); font-size: clamp(28px, 4vw, 38px); font-weight: 900; letter-spacing: -.03em; }
    .price-soft { color: var(--text-soft); font-size: 17px; font-weight: 700; opacity: .88; }

    .kpi-row { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 14px; margin: 0 0 24px; }
    .kpi {
      padding: 24px 18px 20px;
      border-radius: 24px;
      background: linear-gradient(180deg, rgba(255,255,255,.96) 0%, #fbf5e9 100%);
      border: 1px solid rgba(217,181,109,.20);
      box-shadow: 0 14px 30px rgba(0,0,0,.04);
      text-align: center;
    }
    .kpi strong {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 42px;
      height: 42px;
      margin: 0 auto 10px;
      color: #fff;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, #fff8d6 0%, #f5d27a 25%, #d9b56d 55%, #b89245 100%);
      font-size: 14px;
      font-weight: 900;
    }
    .kpi .value { color: var(--primary); font-size: clamp(18px, 2.4vw, 24px); font-weight: 900; letter-spacing: -.02em; }

    .lead { font-size: 16px; line-height: 1.82; text-align: justify; text-justify: inter-word; hyphens: auto; }
    .params-title { margin: 34px 0 10px; color: var(--primary); font-size: 24px; text-align: center; }
    .params-accent { width: 88px; height: 3px; margin: 0 auto 16px; border-radius: 999px; background: linear-gradient(90deg, var(--gold), var(--primary-soft)); }
    .param {
      padding: 18px 22px;
      border-radius: 20px;
      background: linear-gradient(180deg, rgba(255,255,255,.97) 0%, rgba(247,251,253,.94) 100%);
      border: 1px solid rgba(214,165,93,.16);
      box-shadow: 0 12px 28px rgba(15,23,42,.05);
      font-size: 17px;
      line-height: 1.9;
      text-align: center;
    }
    .param .label { color: var(--muted); font-size: 13px; font-weight: 600; margin-right: 6px; }
    .param .value { margin-right: 14px; color: var(--primary); font-size: 16px; font-weight: 800; }

    .why-grid, .audience-grid { display: grid; grid-template-columns: repeat(3, minmax(0,1fr)); gap: 18px; margin-top: 24px; }
    .why-item, .audience-card {
      padding: 22px 20px;
      border-radius: 22px;
      border: 1px solid rgba(217,181,109,.18);
      background: linear-gradient(180deg, rgba(255,255,255,.95), rgba(250,246,238,.92));
      box-shadow: 0 10px 24px rgba(15,23,42,.05);
    }
    .why-item strong, .audience-card strong { display: block; margin-bottom: 8px; color: var(--primary); font-size: 17px; line-height: 1.3; }
    .why-item p, .audience-card p { margin: 0; line-height: 1.65; font-size: 14px; }

    .section-card h2, .cta-box h2 {
      position: relative;
      padding-bottom: 12px;
      color: var(--primary);
      font-size: clamp(30px, 4vw, 42px);
      letter-spacing: -.03em;
    }
    .section-card h2::after, .cta-box h2::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: 0;
      width: 70px;
      height: 3px;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--gold), transparent);
    }

    .contact-box { text-align: center; background: linear-gradient(180deg, #fff 0%, #f8fbfd 100%); }
    .agent-card {
      display: grid;
      grid-template-columns: 1fr 120px;
      gap: 24px;
      align-items: center;
      max-width: 980px;
      margin: 0 auto 28px;
      padding: 24px;
      border-radius: 24px;
      background: rgba(255,255,255,.86);
      border: 1px solid rgba(217,181,109,.16);
      box-shadow: var(--shadow-soft);
      text-align: left;
    }
    .agent-avatar {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      object-fit: cover;
      justify-self: end;
      border: 3px solid rgba(243,199,123,.26);
      box-shadow: 0 16px 34px rgba(15,23,42,.14);
    }
    .agent-name { margin: 0 0 4px; color: var(--primary); font-size: 24px; font-weight: 900; line-height: 1.08; }
    .agent-role { margin: 0 0 6px; color: var(--gold-dark); font-size: 15px; font-weight: 800; letter-spacing: .02em; }
    .agent-meta { margin: 0; color: var(--text-soft); font-size: 14px; line-height: 1.7; }

    .cta-actions, .share-actions { display: flex; flex-wrap: wrap; justify-content: center; gap: 12px; }
    .cta-actions { margin: 4px 0 18px; max-width: 520px; margin-left: auto; margin-right: auto; }
    /* equal width buttons on desktop */
    .cta-actions .btn { flex: 1 1 0; min-width: 220px; }

    .btn, .share-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 14px 22px;
      min-height: 52px;
      border-radius: 999px;
      font-weight: 700;
      font-size: 15px;
      line-height: 1;
      position: relative;
      cursor: pointer;
      text-align: center;
      border: 1px solid rgba(255,255,255,.34);
      backdrop-filter: blur(18px) saturate(140%);
      -webkit-backdrop-filter: blur(18px) saturate(140%);
      box-shadow: 0 10px 24px rgba(0,0,0,.12), inset 0 1px 0 rgba(255,255,255,.28);
      transition: all .25s ease;
    }
    .btn::before, .share-btn::before {
      content: "";
      position: absolute;
      inset: 1px;
      border-radius: inherit;
      background: linear-gradient(180deg, rgba(255,255,255,.30), rgba(255,255,255,.06));
      pointer-events: none;
    }
    .btn > *, .share-btn > * { position: relative; z-index: 1; }
    .btn:hover, .share-btn:hover {
      transform: translateY(-2px);
      box-shadow: 0 18px 40px rgba(0,0,0,.16), inset 0 1px 0 rgba(255,255,255,.34);
    }
    .btn-main {
      background: linear-gradient(135deg, rgba(24,55,70,.74), rgba(35,78,99,.60));
      color: #fff;
    }
    .btn-light {
      background: linear-gradient(135deg, rgba(24,55,70,.60), rgba(35,78,99,.46));
      color: #fff;
    }
    #waBtn, .contact-form .btn-main {
      background: linear-gradient(135deg, rgba(37,211,102,.88), rgba(18,140,126,.78));
      color: #fff;
      border: 1px solid rgba(255,255,255,.24);
      box-shadow: 0 12px 28px rgba(18,140,126,.24), inset 0 1px 0 rgba(255,255,255,.18);
    }
    #waBtn:hover, .contact-form .btn-main:hover {
      background: linear-gradient(135deg, rgba(43,224,112,.94), rgba(20,154,138,.84));
    }
    .share-btn {
      background: linear-gradient(135deg, rgba(255,255,255,.86), rgba(255,255,255,.58));
      color: var(--primary);
      border: 1px solid rgba(255,255,255,.74);
      box-shadow: 0 10px 24px rgba(0,0,0,.10), inset 0 1px 0 rgba(255,255,255,.74);
    }
    .share-btn:hover {
      background: linear-gradient(135deg, rgba(255,255,255,.94), rgba(255,255,255,.66));
      color: var(--primary);
    }

    .share-block { max-width: 760px; margin: 24px auto 0; padding-top: 20px; border-top: 1px solid rgba(15,23,42,.08); }
    .share-note { margin: 12px 0 0; color: var(--muted); font-size: 13px; text-align: center; }
    .urgency-note {
      margin: 0 0 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      padding: 10px 16px;
      border-radius: 999px;
      background: rgba(217,181,109,.12);
      border: 1px solid rgba(217,181,109,.22);
      color: var(--gold-dark);
      font-size: 13px;
      font-weight: 800;
      letter-spacing: .02em;
    }

    .contact-form { display: grid; gap: 14px; margin-top: 24px; text-align: left; }
    .contact-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .contact-form input, .contact-form textarea {
      width: 100%;
      padding: 15px 16px;
      border-radius: 18px;
      border: 1px solid rgba(31,111,133,.12);
      background: rgba(255,255,255,.82);
      color: var(--text);
      outline: none;
      font-family: inherit;
      font-size: 16px;
    }
    .contact-form textarea { min-height: 130px; resize: vertical; }
    .contact-form .btn-main { width: 100%; min-height: 54px; }

    .media-lightbox {
      position: fixed;
      inset: 0;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 24px;
      background: rgba(5,10,16,.94);
      z-index: 9999;
    }
    .media-lightbox.open { display: flex; }
    .media-lightbox-inner {
      position: relative;
      width: min(1100px, 92vw);
      max-height: 90vh;
      border-radius: 24px;
      overflow: hidden;
      background: #0b141c;
      box-shadow: 0 28px 70px rgba(0,0,0,.35);
    }
    .media-lightbox img { width: 100%; max-height: 90vh; object-fit: contain; background: #0b141c; }
    .media-lightbox-close {
      position: absolute;
      top: 14px;
      right: 14px;
      z-index: 2;
      width: 42px;
      height: 42px;
      border: none;
      border-radius: 999px;
      background: rgba(255,255,255,.16);
      color: #fff;
      font-size: 24px;
      cursor: pointer;
    }

    .topbar, .breadcrumbs, .footer, .footer-card, .contact-links, .footer-bottom, .footer-copy, .footer-brand { display: none !important; }

    @media (max-width:1100px) {
      .hero-media, .hero-media img { min-height: 520px; }
      .why-grid, .audience-grid { grid-template-columns: 1fr; }
    }

    @media (max-width:980px) {
      .hero-media, .hero-media img { min-height: 430px; }
      .hero-overlay { left: 18px; right: 18px; bottom: 18px; }
      .gallery-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
    }

    @media (max-width:768px) {
      body { padding-bottom: 24px; }
      .container { padding: 0 14px; }
      .page { padding: 18px 0 50px; }
      .section-card, .cta-box { padding: 24px; }
      .top-controls { display: grid; grid-template-columns: minmax(0,1fr) auto; align-items: center; gap: 10px; }
      .lang-switcher { justify-content: flex-end; width: auto; margin: 0; gap: 8px; }
      .hero-media, .hero-media img { min-height: 340px; }
      .hero-overlay { flex-direction: column; align-items: flex-start; gap: 12px; left: 14px; right: 14px; bottom: 14px; }
      .hero-copy { max-width: 100%; width: 100%; }
      .hero-display { font-size: clamp(28px, 7vw, 40px); max-width: 100%; }
      .hero-sub { font-size: 13px; }
      .hero-price-box { min-width: 0; width: 100%; max-width: 100%; padding: 16px 16px 14px; }
      .hero-price-range { gap: 8px; }
      .hero-price-from, .hero-price-to { min-width: 0; flex: 1 1 0; font-size: clamp(22px, 7vw, 30px); padding: 12px 14px 10px; }
      .hero-price-sep { padding-bottom: 6px; font-size: 18px; }
      .kpi-row, .contact-form-grid, .why-grid, .audience-grid { grid-template-columns: 1fr; }
      .gallery-grid { grid-template-columns: repeat(2, minmax(0,1fr)); gap: 12px; }
      .gallery-item { min-height: 150px; border-radius: 18px; }
      .cta-actions, .share-actions { flex-direction: column; }
      .cta-actions .btn, .share-actions .share-btn, .contact-form .btn-main { width: 100%; }
      .agent-card { grid-template-columns: 1fr; text-align: center; gap: 16px; }
      .agent-avatar { margin: 0 auto; justify-self: center; order: -1; }
      .agent-meta { text-align: center; }
      .back-link { width: 100%; justify-content: center; position: static; margin-bottom: 0; padding: 11px 14px; font-size: 14px; white-space: nowrap; }
    }

    @media (max-width:560px) {
      .container { padding: 0 10px; }
      .hero-card, .section-card, .cta-box { border-radius: 18px; }
      .hero-media, .hero-media img { min-height: 280px; }
      .hero-badge { top: 12px; right: 12px; min-height: 36px; padding: 0 11px; font-size: 10px; }
      .hero-overlay { left: 12px; right: 12px; bottom: 12px; gap: 12px; }
      .hero-kicker { font-size: 10px; letter-spacing: .18em; padding: 9px 12px; }
      .hero-display { font-size: clamp(26px, 8vw, 38px); }
      .hero-price-range { gap: 6px; }
      .hero-price-from, .hero-price-to { width: 100%; font-size: 28px; padding: 12px 12px 10px; }
      .hero-price-sep { width: 100%; text-align: center; padding: 0; font-size: 16px; }
      .hero-title { font-size: clamp(30px, 9vw, 40px); }
      .price { font-size: 24px; }
      .lead, p { font-size: 15px; }
      .param { font-size: 14px; line-height: 1.8; }
      .section-card, .cta-box, .why-item, .audience-card { padding: 20px; }
      .gallery-grid { grid-template-columns: 1fr; gap: 10px; }
      .gallery-item { min-height: 220px; }
      .cta-actions, .share-actions { flex-direction: column; }
      .cta-actions .btn, .share-actions .share-btn, .contact-form .btn-main { width: 100%; }
      .btn, .share-btn { min-height: 54px; font-size: 14px; }
      .subtitle, .price-soft, .share-note { font-size: 14px; }
      .top-controls { grid-template-columns: minmax(0,1fr) auto; gap: 8px; }
      .lang-btn { width: 28px; height: 28px; font-size: 9px; }
      .back-link { font-size: 13px; padding: 10px 12px; }
    }
  </style>
</head>
<body>
  <main class="page">
    <div class="container">
      <div class="top-controls">
        <a class="back-link" id="backLink" href="https://costa-blanca-invest.com/pl/plots/" translate="no">
          <svg aria-hidden="true" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          <span id="backLinkLabel">Zobacz inne działki</span>
        </a>
        <div class="lang-switcher" aria-label="Language switcher">
          <button class="lang-btn active" data-lang="pl">PL</button>
          <button class="lang-btn" data-lang="en">EN</button>
          <button class="lang-btn" data-lang="es">ES</button>
          <button class="lang-btn" data-lang="ru">RU</button>
        </div>
      </div>

      <section class="hero-card">
        <div class="hero-media" data-media-src="1.jpg">
          <img id="heroImage" src="1.jpg" alt="Działka na pierwszej linii morza w Villajoyosa" fetchpriority="high" decoding="async" onerror="window.handleBrokenImage && window.handleBrokenImage(this)">
          <div class="hero-badge" data-i18n="badge_text">PIERWSZA LINIA MORZA</div>
          <div class="hero-overlay">
            <div class="hero-copy">
              <div class="hero-kicker" data-i18n="kicker">VILLAJOYOSA · PIERWSZA LINIA MORZA · PROJEKT DEWELOPERSKI</div>
              <div class="hero-display" data-i18n="hero_title">Działka w Villajoyosa</div>
              <p class="hero-sub" data-i18n="hero_subtext">Działka na pierwszej linii morza przeznaczona pod budowę dwóch budynków mieszkalnych (łącznie 24 apartamenty). Wyjątkowa lokalizacja z bezpośrednim widokiem na morze.</p>
            </div>
            <div class="hero-price-box">
              <small data-i18n="hero_price_box_title">ASKING PRICE</small>
              <div class="hero-price-range">
                <span class="hero-price-from" data-i18n="hero_price_value_1">€3.2M</span>
                <span class="hero-price-sep" data-i18n="hero_price_sep">→</span>
                <span class="hero-price-to" data-i18n="hero_price_value_2">24 units</span>
              </div>
              <span class="hero-price-note" data-i18n="hero_price_note">2 budynki · 24 apartamenty · pierwsza linia morza</span>
              <span class="hero-price-meta" data-i18n="hero_price_meta">projekt deweloperski premium</span>
            </div>
          </div>
        </div>

        <div class="gallery-grid" aria-label="Dodatkowe zdjęcia działki">
          <div class="gallery-item" data-media-src="2.jpg"><img src="2.jpg" alt="" loading="lazy"></div>
          <div class="gallery-item" data-media-src="3.jpg"><img src="3.jpg" alt="" loading="lazy"></div>
          <div class="gallery-item" data-media-src="4.jpg"><img src="4.jpg" alt="" loading="lazy"></div>
          <div class="gallery-item" data-media-src="5.jpg"><img src="5.jpg" alt="" loading="lazy"></div>
          <div class="gallery-item" data-media-src="6.jpg"><img src="6.jpg" alt="" loading="lazy"></div>
          <div class="gallery-item" data-media-src="7.jpg"><img src="7.jpg" alt="" loading="lazy"></div>
          <div class="gallery-item" data-media-src="8.jpg"><img src="8.jpg" alt="" loading="lazy"></div>
          <div class="gallery-item" data-media-src="9.jpg"><img src="9.jpg" alt="" loading="lazy"></div>
        </div>
      </section>

      <div class="content">
        <h1 class="hero-title" data-i18n="page_h1">DZIAŁKA NA SPRZEDAŻ NA PIERWSZEJ LINII MORZA W VILLAJOYOSA</h1>
        <div class="subtitle" data-i18n="subtitle">Hiszpania · Villajoyosa · działka pod 2 budynki mieszkalne / 24 apartamenty</div>
        <div class="price" data-i18n="price_range">€ 3 200 000</div>
        <div class="price-soft" data-i18n="price_soft">projekt 24 mieszkań · pierwsza linia morza · widok na morze</div>

        <div class="kpi-row" aria-label="Kluczowe parametry działki">
          <div class="kpi"><strong>€</strong><div class="value" data-i18n="kpi_1">3 200 000</div></div>
          <div class="kpi"><strong>24</strong><div class="value" data-i18n="kpi_2">apartamenty</div></div>
          <div class="kpi"><strong>2</strong><div class="value" data-i18n="kpi_3">budynki</div></div>
          <div class="kpi"><strong>SEA</strong><div class="value" data-i18n="kpi_4">pierwsza linia</div></div>
        </div>

        <p class="lead" data-i18n="lead_1">To unikalna oferta inwestycyjna w Villajoyosa, Alicante — działka na pierwszej linii morza przeznaczona pod realizację dwóch budynków mieszkalnych obejmujących łącznie 24 apartamenty.</p>
        <p class="lead" data-i18n="lead_2">Największym atutem nieruchomości jest jej bezpośrednie położenie przy morzu. Taka lokalizacja znacząco podnosi atrakcyjność przyszłego projektu i wzmacnia jego potencjał sprzedażowy.</p>
        <p class="lead" data-i18n="lead_3">To propozycja skierowana do inwestora lub dewelopera, który szuka projektu premium na Costa Blanca z bardzo mocnym pozycjonowaniem rynkowym i wyjątkowym widokiem na morze.</p>

        <h2 class="params-title" data-i18n="params_title">Parametry działki</h2>
        <div class="params-accent"></div>
        <div class="param">
          <span class="label" data-i18n="param_label_1">Lokalizacja:</span><span class="value" data-i18n="param_value_1">Villajoyosa, Alicante</span>
          <span class="label" data-i18n="param_label_2">Cena:</span><span class="value" data-i18n="param_value_2">€ 3 200 000</span>
          <span class="label" data-i18n="param_label_3">Projekt:</span><span class="value" data-i18n="param_value_3">2 budynki / 24 apartamenty</span>
          <span class="label" data-i18n="param_label_4">Linia:</span><span class="value" data-i18n="param_value_4">pierwsza linia morza</span>
          <span class="label" data-i18n="param_label_5">Widok:</span><span class="value" data-i18n="param_value_5">bezpośredni widok na morze</span>
          <span class="label" data-i18n="param_label_6">Typ:</span><span class="value" data-i18n="param_value_6">deweloperska (mieszkaniowa)</span>
        </div>
      </div>

      <section class="section-card" id="investment-benefits">
        <h2 data-i18n="why_section_title">Dlaczego ten projekt jest atrakcyjny?</h2>
        <div class="why-grid">
          <div class="why-item"><strong data-i18n="why_title_1">🌊 Pierwsza linia morza</strong><p data-i18n="why_text_1">Bezpośrednie położenie przy morzu i panoramiczne widoki tworzą wyjątkową przewagę lokalizacyjną dla projektu mieszkaniowego premium.</p></div>
          <div class="why-item"><strong data-i18n="why_title_2">🏗 Skala projektu</strong><p data-i18n="why_text_2">Działka przeznaczona jest pod realizację dwóch budynków mieszkalnych obejmujących łącznie 24 apartamenty.</p></div>
          <div class="why-item"><strong data-i18n="why_title_3">📈 Potencjał deweloperski</strong><p data-i18n="why_text_3">To mocna propozycja dla inwestora szukającego projektu z wysokim potencjałem komercyjnym w topowej lokalizacji Costa Blanca.</p></div>
        </div>
      </section>

      <section class="section-card" id="spec">
        <h2 data-i18n="spec_title">Co otrzymuje kupujący</h2>
        <ul>
          <li data-i18n="spec_1">Działkę na pierwszej linii morza w Villajoyosa</li>
          <li data-i18n="spec_2">Projekt pod 2 budynki mieszkalne</li>
          <li data-i18n="spec_3">Łącznie 24 apartamenty</li>
          <li data-i18n="spec_4">Bezpośredni widok na morze</li>
          <li data-i18n="spec_5">Topowa lokalizacja na Costa Blanca</li>
          <li data-i18n="spec_6">Wysoki potencjał dla projektu deweloperskiego</li>
        </ul>
        <p data-i18n="spec_paragraph">To oferta dla inwestora, który szuka nie tylko działki, ale konkretnej skali projektu w lokalizacji premium z bardzo mocnym argumentem sprzedażowym.</p>
      </section>

      <section class="section-card" id="roi">
        <h2 data-i18n="roi_title">Potencjał nieruchomości</h2>
        <p class="lead" data-i18n="roi_paragraph_1">Największą wartością tego gruntu jest połączenie pierwszej linii morza, projektu 24 apartamentów oraz lokalizacji Villajoyosa, która ma silny potencjał dla produktu mieszkaniowego premium.</p>
        <ul>
          <li><strong data-i18n="roi_label_1">Format:</strong> <span data-i18n="roi_value_1">2 budynki mieszkalne / 24 apartamenty</span></li>
          <li><strong data-i18n="roi_label_2">Lokalizacja:</strong> <span data-i18n="roi_value_2">pierwsza linia morza · Villajoyosa, Alicante</span></li>
          <li><strong data-i18n="roi_label_3">Przeznaczenie:</strong> <span data-i18n="roi_value_3">grunt pod projekt deweloperski mieszkaniowy</span></li>
          <li><strong data-i18n="roi_label_4">Atut:</strong> <span data-i18n="roi_value_4">bezpośredni widok na morze i wysoki potencjał komercyjny</span></li>
        </ul>
        <p class="lead" data-i18n="roi_paragraph_2">To propozycja dla dewelopera, który chce wejść w mocny projekt nadmorski z bardzo czytelnym pozycjonowaniem i potencjałem sprzedażowym na rynku Costa Blanca.</p>
      </section>

      <section class="section-card" id="audience-fit">
        <h2 data-i18n="audience_title">Dla kogo jest ten projekt?</h2>
        <div class="audience-grid">
          <div class="audience-card"><strong data-i18n="audience_card_1_title">🏗 Dla dewelopera</strong><p data-i18n="audience_card_1_text">Dla inwestora, który szuka działki pod realizację projektu mieszkaniowego premium w wyjątkowej lokalizacji nad morzem.</p></div>
          <div class="audience-card"><strong data-i18n="audience_card_2_title">💼 Dla inwestora</strong><p data-i18n="audience_card_2_text">Dla kupującego, który analizuje aktywa z wysokim potencjałem wzrostu wartości i atrakcyjnym produktem końcowym.</p></div>
          <div class="audience-card"><strong data-i18n="audience_card_3_title">🌊 Dla projektu premium</strong><p data-i18n="audience_card_3_text">Dla koncepcji mieszkaniowej, która ma wykorzystać widok na morze i pierwszą linię jako kluczowy argument sprzedażowy.</p></div>
        </div>
      </section>

      <section class="cta-box contact-box" id="contact">
        <div class="urgency-note" data-i18n="urgency_note">Pierwsza linia morza · projekt deweloperski · wysoki potencjał</div>
        <h2 data-i18n="contact_title">Otrzymaj szczegóły działki</h2>
        <p data-i18n="contact_intro">Skontaktuj się ze mną, aby otrzymać szczegóły dotyczące działki, założeń projektu i potencjału inwestycyjnego tej lokalizacji.</p>

        <div class="agent-card">
          <div>
            <div class="agent-name">Olga Chernyshenko</div>
            <div class="agent-role" data-i18n="agent_role">Ekspert ds. nieruchomości na Costa Blanca</div>
            <p class="agent-meta" data-i18n="agent_meta">Dobór nieruchomości, wsparcie przy zakupie i pomoc na każdym etapie transakcji w Hiszpanii.</p>
          </div>
          <img class="agent-avatar" src="https://costa-blanca-invest.com/avatar.png" alt="Olga Chernyshenko" loading="lazy" decoding="async">
        </div>

        <div class="cta-actions">
          <a class="btn btn-main" href="tel:+34604158859" aria-label="Call">
            <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.08 4.18 2 2 0 0 1 4.06 2h3a2 2 0 0 1 2 1.72c.12.9.37 1.78.73 2.6a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.48-1.48a2 2 0 0 1 2.11-.45c.82.36 1.7.61 2.6.73A2 2 0 0 1 22 16.92z"/></svg>
            <span data-i18n="call_btn">Zadzwoń</span>
          </a>
          <a class="btn btn-light" id="waBtn" href="https://wa.me/34604158859?text=Interesuje%20mnie%20dzia%C5%82ka%20na%20pierwszej%20linii%20morza%20w%20Villajoyosa%20za%20%E2%82%AC%203200000" target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
            <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-4.2-7.6L21 3l-1.4 4.2A9 9 0 0 1 21 12z"/><path d="M8 12h.01M12 12h.01M16 12h.01"/></svg>
            <span data-i18n="wa_btn">WhatsApp</span>
          </a>
        </div>

        <form class="contact-form" id="contact-form" action="#" method="post">
          <div class="contact-form-grid">
            <input type="text" name="name" id="formName" placeholder="Imię" required>
            <input type="tel" name="phone" id="formPhone" placeholder="Telefon" required>
          </div>
          <input type="email" name="email" id="formEmail" placeholder="Email">
          <textarea name="message" id="formMessage" placeholder="Napisz, czy interesuje Cię projekt deweloperski, zakup inwestycyjny lub szczegóły działki"></textarea>
          <button class="btn btn-main" type="submit">
            <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="currentColor"><path d="M20.52 3.48A11.86 11.86 0 0 0 12.07 0C5.56 0 .26 5.29.26 11.8c0 2.08.54 4.1 1.58 5.88L0 24l6.52-1.71a11.8 11.8 0 0 0 5.55 1.41h.01c6.5 0 11.8-5.3 11.8-11.8 0-3.15-1.23-6.1-3.36-8.42Zm-8.45 18.2h-.01a9.84 9.84 0 0 1-5-1.36l-.36-.21-3.87 1.01 1.03-3.77-.24-.39a9.8 9.8 0 0 1-1.5-5.17c0-5.43 4.42-9.85 9.86-9.85 2.63 0 5.1 1.02 6.96 2.88a9.78 9.78 0 0 1 2.88 6.96c0 5.43-4.42 9.85-9.85 9.85Z"/></svg>
            <span data-i18n="form_submit">Wyślij przez WhatsApp</span>
          </button>
        </form>

        <div class="share-block">
          <div class="share-actions" role="group" aria-label="Share">
            <button class="share-btn" type="button" id="copyLinkBtn" aria-label="Copy link">
              <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              <span data-i18n="copy_link">Kopiuj link</span>
            </button>
            <button class="share-btn" type="button" id="nativeShareBtn" aria-label="Share">
              <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.59 13.51 15.42 17.49M15.41 6.51 8.59 10.49"/></svg>
              <span data-i18n="share_btn">Udostępnij</span>
            </button>
          </div>
          <p class="share-note"><span data-i18n="share_note_title">Działka na pierwszej linii morza w Villajoyosa</span><br><strong data-i18n="share_note_strong">€ 3 200 000 · 24 apartamenty · 2 budynki</strong><br><span data-i18n="share_note_text">Bezpośredni widok na morze · projekt premium · wysoki potencjał inwestycyjny</span></p>
        </div>
      </section>
    </div>
  </main>

  <div class="media-lightbox" id="mediaLightbox" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="media-lightbox-inner">
      <button class="media-lightbox-close" type="button" id="mediaLightboxClose" aria-label="Zamknij">×</button>
      <div id="mediaLightboxContent"></div>
